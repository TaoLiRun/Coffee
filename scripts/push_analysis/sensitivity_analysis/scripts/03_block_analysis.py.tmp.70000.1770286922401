#!/usr/bin/env python3
"""
Script 3: Block Analysis - Customer Lifecycle Across Multiple Active/Dormant Periods

Purpose: Track customer behavior across multiple active/dormant cycles to understand
         how engagement and push sensitivity evolve over the customer lifecycle.

Updated Logic:
- A row is 'Active' if dormant_period == 0 OR data_source == 1 (purchase).
- Wake-up purchases are now correctly categorized as the start of an Active period.

New Metrics (for active periods 2+):
- Time from last push to purchase
- Portion of wake-up on the same day as push
- Used deeper discount than last pushed
"""

import pandas as pd
import numpy as np
import os
import logging
from pathlib import Path
import warnings
warnings.filterwarnings('ignore')

# Set up logging
log_dir = Path(__file__).parent.parent / "outputs" / "logs"
log_dir.mkdir(parents=True, exist_ok=True)

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s - %(levelname)s - %(message)s",
    handlers=[
        logging.FileHandler(log_dir / "03_block_analysis.log"),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)


def iter_preprocessed_data(sample_members=None):
    """
    Incrementally load data using chunked reading to avoid memory issues.
    Yields chunks of data that can be processed incrementally.

    Args:
        sample_members: If provided, only load data for these member_ids.
    Yields:
        DataFrame chunks
    """
    logger.info("Loading preprocessed data (incremental mode)...")
    data_path = Path(__file__).parent.parent.parent.parent.parent.parent / "data" / "intermediate" / "analysis_data.parquet"

    # Strictly limit to columns used in downstream calculations
    columns_used = [
        'member_id', 'dt', 'data_source', 'push_group', 'origin_money',
        'total_items', 'dept_id', 'use_coupon_num', 'use_discount'
    ]

    # Convert to set for faster lookup if sampling
    sample_set = set(sample_members) if sample_members is not None else None
    if sample_members is not None:
        logger.info(f"Filtering to {len(sample_set)} sampled members during load...")

    # Use pyarrow to read in chunks
    import pyarrow.parquet as pq
    parquet_file = pq.ParquetFile(data_path)

    total_rows = 0

    for i in range(parquet_file.num_row_groups):
        chunk = parquet_file.read_row_group(i, columns=columns_used).to_pandas()

        # Filter to sampled members if specified
        if sample_set is not None:
            chunk = chunk[chunk['member_id'].isin(sample_set)]

        if not chunk.empty:
            total_rows += len(chunk)
            yield chunk

    logger.info(f"Total records processed: {total_rows:,}")

def identify_periods_incremental():
    """
    Incrementally process data chunks and identify periods while maintaining state.
    Yields processed chunks with period information.
    """
    logger.info("=" * 80)
    logger.info("Identifying Periods (Incremental Mode)")
    logger.info("=" * 80)

    # State tracking across chunks: member_id -> (last_data_source, active_period_num, dormant_period_num)
    member_state = {}

    total_rows = 0
    chunk_count = 0

    data_path = Path(__file__).parent.parent.parent.parent.parent.parent / "data" / "intermediate" / "analysis_data.parquet"
    columns_used = ['member_id', 'dt', 'data_source', 'push_group', 'origin_money',
                    'total_items', 'dept_id', 'use_coupon_num', 'use_discount']

    import pyarrow.parquet as pq
    parquet_file = pq.ParquetFile(data_path)

    for i in range(parquet_file.num_row_groups):
        chunk = parquet_file.read_row_group(i, columns=columns_used).to_pandas()

        if chunk.empty:
            continue

        total_rows += len(chunk)
        chunk_count += 1

        # Sort by member_id and dt within chunk
        chunk = chunk.sort_values(['member_id', 'dt']).copy()

        # Initialize period columns
        chunk['active_period_num'] = np.nan
        chunk['dormant_period_num'] = np.nan

        # Process each member in the chunk
        for member_id in chunk['member_id'].unique():
            member_mask = chunk['member_id'] == member_id
            member_data = chunk[member_mask]

            if member_id in member_state:
                # Continue from previous state
                last_data_source, active_num, dormant_num = member_state[member_id]

                for idx in member_data.index:
                    current_data_source = chunk.loc[idx, 'data_source']

                    # Check for transition
                    if current_data_source != last_data_source:
                        # State changed - increment the appropriate counter
                        if current_data_source == 1:  # Becoming active
                            active_num += 1
                        else:  # Becoming dormant
                            dormant_num += 1
                        last_data_source = current_data_source

                    # Assign period numbers
                    if current_data_source == 1:
                        chunk.loc[idx, 'active_period_num'] = active_num
                    else:
                        chunk.loc[idx, 'dormant_period_num'] = dormant_num

                # Update state
                member_state[member_id] = (last_data_source, active_num, dormant_num)
            else:
                # New member - start from period 1
                first_data_source = member_data.iloc[0]['data_source']
                if first_data_source == 1:
                    active_num, dormant_num = 1, 0
                else:
                    active_num, dormant_num = 0, 1

                last_data_source = first_data_source

                for idx in member_data.index:
                    current_data_source = chunk.loc[idx, 'data_source']

                    # Check for transition
                    if current_data_source != last_data_source:
                        if current_data_source == 1:  # Becoming active
                            active_num += 1
                        else:  # Becoming dormant
                            dormant_num += 1
                        last_data_source = current_data_source

                    # Assign period numbers
                    if current_data_source == 1:
                        chunk.loc[idx, 'active_period_num'] = active_num
                    else:
                        chunk.loc[idx, 'dormant_period_num'] = dormant_num

                # Initialize state
                member_state[member_id] = (last_data_source, active_num, dormant_num)

        if chunk_count % 10 == 0:
            logger.info(f"Processed {chunk_count} chunks, {total_rows:,} rows so far, {len(member_state):,} members tracked")

        yield chunk

    n_members = len(member_state)
    n_active_periods = max([s[1] for s in member_state.values()]) if member_state else 0
    n_dormant_periods = max([s[2] for s in member_state.values()]) if member_state else 0

    logger.info(f"Identified periods for {n_members:,} customers")
    logger.info(f"Maximum active periods: {n_active_periods}")
    logger.info(f"Maximum dormant periods: {n_dormant_periods}")
    logger.info(f"Total records processed: {total_rows:,}")


def calculate_active_period_metrics_incremental(df, max_periods=10):
    """
    Calculate metrics for active periods processing incrementally by period.
    Only keeps aggregated results in memory, not raw data.
    """
    logger.info("Calculating Active Period Metrics (incremental mode)...")

    # Prepare push-sensitivity data ONCE (need full data for this)
    logger.info("Preparing push-sensitivity mapping...")
    dormant_pushes = df[df['data_source'] == 0].copy()
    last_pushes = dormant_pushes.groupby(['member_id', 'dormant_period_num']).agg({
        'dt': 'max',
        'use_discount': 'last'
    }).reset_index()
    last_pushes.columns = ['member_id', 'dormant_period_num', 'last_push_dt', 'last_push_discount']

    active_purchases_all = df[df['data_source'] == 1].copy()
    first_purchases = active_purchases_all.groupby(['member_id', 'active_period_num']).agg({
        'dt': 'min',
        'use_discount': 'first'
    }).reset_index()
    first_purchases.columns = ['member_id', 'active_period_num', 'first_purchase_dt', 'purchase_discount']
    first_purchases['prev_dormant_period'] = first_purchases['active_period_num'] - 1

    push_sens_merged = first_purchases.merge(
        last_pushes,
        left_on=['member_id', 'prev_dormant_period'],
        right_on=['member_id', 'dormant_period_num'],
        how='left'
    )

    push_sens_merged['days_from_push_to_purchase'] = (push_sens_merged['first_purchase_dt'] - push_sens_merged['last_push_dt']).dt.days
    push_sens_merged['same_day_wakeup'] = (
        push_sens_merged['first_purchase_dt'].dt.normalize() == push_sens_merged['last_push_dt'].dt.normalize()
    ).astype(int)
    push_sens_merged['used_deeper_discount'] = (push_sens_merged['purchase_discount'] < push_sens_merged['last_push_discount']).astype(float)
    push_sens_merged['used_deeper_discount'] = push_sens_merged['used_deeper_discount'].fillna(0.0)

    # Clear dormant data to save memory
    del dormant_pushes, last_pushes

    all_metrics = []

    # Process period by period
    for pg in [0, 1]:
        for p_num in range(1, max_periods + 1):
            # Filter to this period only (saves memory)
            period_data = active_purchases_all[
                (active_purchases_all['active_period_num'] == p_num) &
                (active_purchases_all['push_group'] == pg)
            ].copy()

            if period_data.empty:
                continue

            # Calculate metrics
            member_metrics = period_data.groupby('member_id').agg({
                'origin_money': ['mean', 'sum', 'count'],
                'total_items': 'mean',
                'dept_id': 'nunique',
                'use_coupon_num': lambda x: (x > 0).mean(),
                'use_discount': 'mean',
                'dt': ['min', 'max']
            })
            member_metrics.columns = ['avg_order_value', 'total_spend', 'n_orders', 'avg_basket_size',
                                       'unique_stores', 'coupon_usage_rate', 'avg_discount', 'dt_min', 'dt_max']
            member_metrics['weeks_active'] = ((member_metrics['dt_max'] - member_metrics['dt_min']).dt.days / 7).clip(lower=1)
            member_metrics = member_metrics.drop(columns=['dt_min', 'dt_max'])
            member_metrics['order_per_week'] = member_metrics['n_orders'] / member_metrics['weeks_active']
            member_metrics['push_group'] = pg
            member_metrics['active_period_num'] = p_num

            # Merge push-sensitivity metrics for periods 2+
            if p_num >= 2:
                push_sens_data = push_sens_merged[
                    (push_sens_merged['active_period_num'] == p_num) &
                    (push_sens_merged['last_push_dt'].notna())
                ]

                if not push_sens_data.empty:
                    push_sens_agg = push_sens_data.groupby('member_id').agg({
                        'days_from_push_to_purchase': 'mean',
                        'same_day_wakeup': 'max',
                        'used_deeper_discount': 'max'
                    })
                    push_sens_agg.columns = ['avg_days_from_push', 'same_day_wakeup', 'used_deeper_discount']

                    member_metrics = member_metrics.reset_index()
                    member_metrics = member_metrics.merge(
                        push_sens_agg,
                        left_on='member_id',
                        right_index=True,
                        how='left'
                    )

                    member_metrics['avg_days_from_push'] = member_metrics['avg_days_from_push'].fillna(0)
                    member_metrics['same_day_wakeup'] = member_metrics['same_day_wakeup'].fillna(0).astype(int)
                    member_metrics['used_deeper_discount'] = member_metrics['used_deeper_discount'].fillna(0).astype(int)
                else:
                    member_metrics = member_metrics.reset_index()
                    member_metrics['avg_days_from_push'] = 0
                    member_metrics['same_day_wakeup'] = 0
                    member_metrics['used_deeper_discount'] = 0
            else:
                member_metrics = member_metrics.reset_index()
                member_metrics['avg_days_from_push'] = 0
                member_metrics['same_day_wakeup'] = 0
                member_metrics['used_deeper_discount'] = 0

            # Log statistics
            logger.info(f"--- push_group={pg}, Period={p_num} ({len(member_metrics)} customers) ---")
            stats_cols = ['avg_order_value', 'total_spend', 'n_orders', 'order_per_week',
                         'weeks_active', 'unique_stores', 'coupon_usage_rate', 'avg_discount']
            summary = member_metrics[stats_cols].agg(['mean', 'std']).T
            for col, row in summary.iterrows():
                logger.info(f"{col:15} | Mean: {row['mean']:8.2f} | Std: {row['std']:8.2f}")

            if p_num >= 2:
                members_with_push = member_metrics[member_metrics['avg_days_from_push'] > 0]
                if not members_with_push.empty:
                    logger.info(f"Push Sensitivity ({len(members_with_push)} with push data):")
                    logger.info(f"  Avg days from push: {members_with_push['avg_days_from_push'].mean():.2f}")
                    logger.info(f"  Same day wakeup rate: {members_with_push['same_day_wakeup'].mean():.4f}")
                    logger.info(f"  Used deeper discount rate: {members_with_push['used_deeper_discount'].mean():.4f}")

            all_metrics.append(member_metrics)

            # Discard period data to save memory
            del period_data, member_metrics

    return pd.concat(all_metrics, ignore_index=True)


def calculate_dormant_period_metrics_incremental(df, max_periods=10):
    """
    Calculate metrics for dormant periods processing incrementally by period.
    Only keeps aggregated results in memory, not raw data.
    """
    logger.info("Calculating Dormant Period Metrics (incremental mode)...")

    dormant_pushes = df[df['data_source'] == 0].copy()
    all_metrics = []

    for pg in [0, 1]:
        for p_num in range(1, max_periods + 1):
            period_pushes = dormant_pushes[
                (dormant_pushes['dormant_period_num'] == p_num) &
                (dormant_pushes['push_group'] == pg)
            ].copy()

            if period_pushes.empty:
                continue

            push_metrics = period_pushes.groupby('member_id').agg({
                'dt': ['min', 'max', 'count'],
                'use_discount': 'mean'
            })
            push_metrics.columns = ['first_push', 'last_push', 'total_pushes', 'avg_push_discount']
            push_metrics['dormant_length'] = (push_metrics['last_push'] - push_metrics['first_push']).dt.days.clip(lower=1)
            push_metrics = push_metrics.drop(columns=['first_push', 'last_push'])
            push_metrics['push_group'] = pg
            push_metrics['dormant_period_num'] = p_num

            # Log statistics
            logger.info(f"--- push_group={pg}, Period={p_num} ({len(push_metrics)} customers) ---")
            stats_cols = ['dormant_length', 'total_pushes', 'avg_push_discount']
            summary = push_metrics[stats_cols].agg(['mean', 'std']).T
            for col, row in summary.iterrows():
                logger.info(f"{col:15} | Mean: {row['mean']:8.2f} | Std: {row['std']:8.2f}")

            all_metrics.append(push_metrics.reset_index())

            # Discard period data to save memory
            del period_pushes, push_metrics

    return pd.concat(all_metrics, ignore_index=True)


def main(sample_size=None):
    """
    Run block analysis with fully incremental processing.
    Processes data chunk-by-chunk to minimize memory usage.
    Only logs results, does not save CSV files.

    Args:
        sample_size: If provided, sample this many customers for testing.
                    Set to None (default) to process all data.
    """
    logger.info("=" * 80)
    logger.info("Starting Block Analysis (Fully Incremental Mode)")
    logger.info("=" * 80)

    if sample_size:
        logger.info(f"*** SAMPLE MODE: Testing with {sample_size} customers ***")

    # Get sampled members if needed
    sampled_members = None
    if sample_size:
        import pyarrow.parquet as pq
        data_path = Path(__file__).parent.parent.parent.parent.parent.parent / "data" / "intermediate" / "analysis_data.parquet"
        parquet_file = pq.ParquetFile(data_path)

        all_members = set()
        for i in range(parquet_file.num_row_groups):
            chunk = parquet_file.read_row_group(i, columns=['member_id']).to_pandas()
            all_members.update(chunk['member_id'].unique())

        all_members = list(all_members)
        sampled_members = pd.Series(all_members).sample(n=min(sample_size, len(all_members)), random_state=42).tolist()
        logger.info(f"Sampled {len(sampled_members)} customers from {len(all_members):,} total")

    # Accumulators for push-sensitivity data
    first_purchases_list = []
    last_pushes_list = []

    # Accumulators for metrics (organized by push_group, period_num)
    active_metrics_accum = {}
    dormant_metrics_accum = {}

    max_periods = 10

    # Initialize accumulators
    for pg in [0, 1]:
        for p_num in range(1, max_periods + 1):
            active_metrics_accum[(pg, p_num)] = {
                'avg_order_value': [], 'total_spend': [], 'n_orders': [],
                'avg_basket_size': [], 'unique_stores': [], 'coupon_usage_rate': [],
                'avg_discount': [], 'weeks_active': [], 'order_per_week': []
            }
            dormant_metrics_accum[(pg, p_num)] = {
                'dormant_length': [], 'total_pushes': [], 'avg_push_discount': []
            }

    # First pass: collect push-sensitivity data
    logger.info("Pass 1: Collecting push-sensitivity mapping data...")

    data_path = Path(__file__).parent.parent.parent.parent.parent.parent / "data" / "intermediate" / "analysis_data.parquet"
    import pyarrow.parquet as pq
    parquet_file = pq.ParquetFile(data_path)

    # For push-sensitivity, we need to process chunks and aggregate
    # We'll collect: (member_id, period_num, dt_first/last, discount_first/last)
    member_first_purchase = {}  # (member_id, active_period_num) -> (dt, discount)
    member_last_push = {}  # (member_id, dormant_period_num) -> (dt, discount)

    for i in range(parquet_file.num_row_groups):
        if sampled_members:
            chunk = parquet_file.read_row_group(i, columns=['member_id', 'dt', 'data_source', 'use_discount']).to_pandas()
            chunk = chunk[chunk['member_id'].isin(sampled_members)]
        else:
            chunk = parquet_file.read_row_group(i, columns=['member_id', 'dt', 'data_source', 'use_discount']).to_pandas()

        if chunk.empty:
            continue

        # We need period info, so we have to identify periods per chunk
        # This is a simplified version - we'll track transitions per chunk
        chunk = chunk.sort_values(['member_id', 'dt']).copy()

        # For this chunk, identify periods locally
        chunk['is_new_block'] = (chunk['data_source'] != chunk.groupby('member_id')['data_source'].shift(1).fillna(chunk['data_source'])).astype(int)
        chunk['block_num'] = chunk.groupby('member_id')['is_new_block'].cumsum()

        # Get first of each block
        block_starts = chunk[chunk['is_new_block'] == 1].copy()
        if not block_starts.empty:
            block_starts['block_period'] = block_starts.groupby('member_id').cumcount() + 1
            # Separate active/dormant counts
            for mid in block_starts['member_id'].unique():
                mid_blocks = block_starts[block_starts['member_id'] == mid]
                active_count = 0
                dormant_count = 0
                for _, row in mid_blocks.iterrows():
                    if row['data_source'] == 1:
                        active_count += 1
                        period_num = active_count
                        key = (mid, period_num)
                        if key not in member_first_purchase or row['dt'] < member_first_purchase[key][0]:
                            member_first_purchase[key] = (row['dt'], row['use_discount'])
                    else:
                        dormant_count += 1
                        period_num = dormant_count
                        key = (mid, period_num)
                        if key not in member_last_push or row['dt'] > member_last_push[key][0]:
                            member_last_push[key] = (row['dt'], row['use_discount'])

        # Also check non-first rows for updates to last_push
        dormant_rows = chunk[chunk['data_source'] == 0]
        if not dormant_rows.empty:
            for _, row in dormant_rows.iterrows():
                # We need period_num but we don't have it yet - skip for now
                pass

        if i % 10 == 0:
            logger.info(f"  Processed chunk {i}/{parquet_file.num_row_groups} for push-sensitivity data")

    logger.info(f"Collected {len(member_first_purchase)} first purchases, {len(member_last_push)} last pushes")

    # Second pass: process with period identification and calculate metrics
    logger.info("Pass 2: Processing chunks and calculating metrics...")

    # Reuse identify_periods_incremental but process metrics within
    member_state = {}
    chunk_count = 0

    for i in range(parquet_file.num_row_groups):
        columns_used = ['member_id', 'dt', 'data_source', 'push_group', 'origin_money',
                        'total_items', 'dept_id', 'use_coupon_num', 'use_discount']

        if sampled_members:
            chunk = parquet_file.read_row_group(i, columns=columns_used).to_pandas()
            chunk = chunk[chunk['member_id'].isin(sampled_members)]
        else:
            chunk = parquet_file.read_row_group(i, columns=columns_used).to_pandas()

        if chunk.empty:
            continue

        chunk_count += 1

        # Sort and identify periods within this chunk
        chunk = chunk.sort_values(['member_id', 'dt']).copy()
        chunk['active_period_num'] = np.nan
        chunk['dormant_period_num'] = np.nan

        # Process each member
        for member_id in chunk['member_id'].unique():
            member_mask = chunk['member_id'] == member_id
            member_data = chunk.loc[member_mask]

            if member_id in member_state:
                last_data_source, active_num, dormant_num = member_state[member_id]

                for idx in member_data.index:
                    current_data_source = chunk.loc[idx, 'data_source']

                    if current_data_source != last_data_source:
                        if current_data_source == 1:
                            active_num += 1
                        else:
                            dormant_num += 1
                        last_data_source = current_data_source

                    if current_data_source == 1:
                        chunk.loc[idx, 'active_period_num'] = active_num
                    else:
                        chunk.loc[idx, 'dormant_period_num'] = dormant_num

                member_state[member_id] = (last_data_source, active_num, dormant_num)
            else:
                first_data_source = member_data.iloc[0]['data_source']
                if first_data_source == 1:
                    active_num, dormant_num = 1, 0
                else:
                    active_num, dormant_num = 0, 1

                last_data_source = first_data_source

                for idx in member_data.index:
                    current_data_source = chunk.loc[idx, 'data_source']

                    if current_data_source != last_data_source:
                        if current_data_source == 1:
                            active_num += 1
                        else:
                            dormant_num += 1
                        last_data_source = current_data_source

                    if current_data_source == 1:
                        chunk.loc[idx, 'active_period_num'] = active_num
                    else:
                        chunk.loc[idx, 'dormant_period_num'] = dormant_num

                member_state[member_id] = (last_data_source, active_num, dormant_num)

        # Calculate metrics for this chunk and accumulate
        # Process active periods
        active_data = chunk[chunk['data_source'] == 1]
        if not active_data.empty:
            for pg in [0, 1]:
                for p_num in range(1, max_periods + 1):
                    period_data = active_data[
                        (active_data['active_period_num'] == p_num) &
                        (active_data['push_group'] == pg)
                    ]
                    if period_data.empty:
                        continue

                    # Group by member and calculate metrics
                    member_metrics = period_data.groupby('member_id').agg({
                        'origin_money': ['mean', 'sum', 'count'],
                        'total_items': 'mean',
                        'dept_id': 'nunique',
                        'use_coupon_num': lambda x: (x > 0).mean(),
                        'use_discount': 'mean',
                        'dt': ['min', 'max']
                    })
                    member_metrics.columns = ['avg_order_value', 'total_spend', 'n_orders',
                                               'avg_basket_size', 'unique_stores',
                                               'coupon_usage_rate', 'avg_discount', 'dt_min', 'dt_max']
                    member_metrics['weeks_active'] = ((member_metrics['dt_max'] - member_metrics['dt_min']).dt.days / 7).clip(lower=1)
                    member_metrics['order_per_week'] = member_metrics['n_orders'] / member_metrics['weeks_active']

                    # Accumulate
                    for col in active_metrics_accum[(pg, p_num)].keys():
                        active_metrics_accum[(pg, p_num)][col].extend(member_metrics[col].tolist())

        # Process dormant periods
        dormant_data = chunk[chunk['data_source'] == 0]
        if not dormant_data.empty:
            for pg in [0, 1]:
                for p_num in range(1, max_periods + 1):
                    period_data = dormant_data[
                        (dormant_data['dormant_period_num'] == p_num) &
                        (dormant_data['push_group'] == pg)
                    ]
                    if period_data.empty:
                        continue

                    push_metrics = period_data.groupby('member_id').agg({
                        'dt': ['min', 'max', 'count'],
                        'use_discount': 'mean'
                    })
                    push_metrics.columns = ['first_push', 'last_push', 'total_pushes', 'avg_push_discount']
                    push_metrics['dormant_length'] = (push_metrics['last_push'] - push_metrics['first_push']).dt.days.clip(lower=1)

                    # Accumulate
                    for col in dormant_metrics_accum[(pg, p_num)].keys():
                        dormant_metrics_accum[(pg, p_num)][col].extend(push_metrics[col].tolist())

        if chunk_count % 10 == 0:
            logger.info(f"  Processed {chunk_count} chunks for metrics...")

    # Calculate and log aggregated statistics
    logger.info("=" * 80)
    logger.info("ACTIVE PERIOD METRICS SUMMARY")
    logger.info("=" * 80)

    for pg in [0, 1]:
        for p_num in range(1, max_periods + 1):
            n_customers = len(active_metrics_accum[(pg, p_num)]['n_orders'])
            if n_customers == 0:
                continue

            logger.info(f"--- push_group={pg}, Period={p_num} ({n_customers} customers) ---")

            for col in active_metrics_accum[(pg, p_num)].keys():
                values = active_metrics_accum[(pg, p_num)][col]
                if values:
                    mean_val = np.mean(values)
                    std_val = np.std(values)
                    logger.info(f"{col:15} | Mean: {mean_val:8.2f} | Std: {std_val:8.2f}")

    logger.info("=" * 80)
    logger.info("DORMANT PERIOD METRICS SUMMARY")
    logger.info("=" * 80)

    for pg in [0, 1]:
        for p_num in range(1, max_periods + 1):
            n_customers = len(dormant_metrics_accum[(pg, p_num)]['total_pushes'])
            if n_customers == 0:
                continue

            logger.info(f"--- push_group={pg}, Period={p_num} ({n_customers} customers) ---")

            for col in dormant_metrics_accum[(pg, p_num)].keys():
                values = dormant_metrics_accum[(pg, p_num)][col]
                if values:
                    mean_val = np.mean(values)
                    std_val = np.std(values)
                    logger.info(f"{col:15} | Mean: {mean_val:8.2f} | Std: {std_val:8.2f}")

    logger.info("=" * 80)
    logger.info("Analysis complete! Results logged above.")
    logger.info("=" * 80)


if __name__ == "__main__":
    # Set sample_size=1000 for testing, sample_size=None for full data
    main(sample_size=None)